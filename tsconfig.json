{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "allowJs": true,
        //"resolveJsonModule": true,
        "moduleDetection": "force",
        "isolatedModules": true,
        // Enable strict type checking to catch bugs early
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        // Transpile TypeScript code to JavaScript
        "module": "ESNext",
        "outDir": "dist",
        // DOM types
        "lib": [
            "ES6",
            "dom",
            "dom.iterable"
        ],
        "types": ["node", "electron"]
    },
    // Necessary files for the project
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/Renderer.js", "src/Preload.js", "src/App.js"  ],
    "exclude": [
        "node_modules"
    ]
}